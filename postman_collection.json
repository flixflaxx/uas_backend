		{
			"name": "Autentikasi",
			"item": [
				{
					"name": "Register Customer Baru",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Eko Prasetyo\",\n    \"email\": \"eko@email.com\",\n    \"password\": \"eko123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login User / Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response && response.session && response.session.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", response.session.token);",
									"    console.log(\"Token JWT berhasil disimpan ke variabel: \", response.session.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@toko.com\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Mengembalikan session dan token JWT. Token admin123/admin@toko.com secara otomatis disimpan di variabel koleksi untuk autorisasi request berikutnya."
					},
					"response": []
				}
			]
		},
